rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Cada usuario autenticado so pode acessar o proprio documento.
    // O {userId} da URL precisa ser igual ao uid recebido pelo Firebase Auth.
    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;

      // As tarefas ficam dentro de users/{uid}/tasks.
      // Assim um aluno logado nao consegue ler nem alterar tarefas de outro.
      match /tasks/{taskId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }
    }

    // Disciplinas ficam em colecao raiz com campo userId.
    // Cada usuario so acessa documentos onde userId bate com o uid dele.
    // Split entre create e read/update/delete evita que o Firestore tente
    // avaliar resource.data.userId em uma operacao create, onde resource
    // ainda nao existe e a avaliacao com erro derruba toda a checagem.
    match /subjects/{subjectId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }
  }
}
